# Copy this file to /sites/<name>.caddy and customize for your needs.
# This example demonstrates ALTCHA integration using stardothosting/caddy-altcha plugin.
#
# ALTCHA provides privacy-friendly spam protection using cryptographic proof-of-work
# challenges. No cookies, no tracking, no third-party services required.
#
# Plugin: https://github.com/stardothosting/caddy-altcha
# Documentation: Complete examples at the plugin repository

# IMPORTANT: Set ALTCHA_HMAC_KEY environment variable before starting Caddy
# Generate with: openssl rand -base64 32
# This key MUST be the same in both altcha_challenge and altcha_verify handlers

# =============================================================================
# EXAMPLE 1: Basic Form Protection (Memory Backend)
# =============================================================================
form.example.com {
    # DNS-01 challenge for automatic HTTPS
    tls {
        dns cloudns {
            auth_id {$CLOUDNS_AUTH_ID}
            auth_password {$CLOUDNS_AUTH_PASSWORD}
        }
        propagation_delay 2m
        propagation_timeout -1
        resolvers 1.1.1.1 8.8.8.8
    }

    # CRITICAL: Set order for altcha_verify to run before reverse_proxy
    order altcha_verify before reverse_proxy

    # Challenge generation endpoint - required for widget
    route /api/altcha/challenge {
        altcha_challenge {
            hmac_key {env.ALTCHA_HMAC_KEY}
            algorithm SHA-256
            max_number 100000      # ~20ms solve time
            expires 5m             # Challenge validity
        }
    }

    # Challenge UI page (contains ALTCHA widget)
    route /captcha* {
        rewrite * /index.html
        root * /var/www/altcha
        file_server
    }

    # Protect form submission endpoints
    @protected {
        path /submit /contact /register
        method POST
    }

    altcha_verify @protected {
        hmac_key {env.ALTCHA_HMAC_KEY}
        session_backend memory://
        challenge_redirect /captcha
        preserve_post_data true    # Restore POST data after verification
    }

    # Your application
    reverse_proxy http://127.0.0.1:8080
}

# =============================================================================
# EXAMPLE 2: Contact Form with Redis (Production Setup)
# =============================================================================
contact.example.com {
    tls {
        dns cloudns {
            auth_id {$CLOUDNS_AUTH_ID}
            auth_password {$CLOUDNS_AUTH_PASSWORD}
        }
        propagation_delay 2m
        propagation_timeout -1
        resolvers 1.1.1.1 8.8.8.8
    }

    order altcha_verify before reverse_proxy
    import security_headers

    # Challenge endpoint with rate limiting (prevent DoS)
    route /api/altcha/challenge {
        altcha_challenge {
            hmac_key {env.ALTCHA_HMAC_KEY}
            algorithm SHA-256
            max_number 1000000         # ~200ms solve time (recommended)
            expires 5m
            rate_limit_requests 10     # Max 10 challenges per IP
            rate_limit_window 1m       # Per minute
        }
    }

    # Challenge UI page
    route /captcha* {
        rewrite * /index.html
        root * /var/www/altcha
        file_server
    }

    # Protect contact form with Redis session backend
    @contact {
        path /contact/submit
        method POST
    }

    altcha_verify @contact {
        hmac_key {env.ALTCHA_HMAC_KEY}
        session_backend redis://localhost:6379/0
        session_ttl 5m
        challenge_redirect /captcha
        preserve_post_data true

        # Cookie configuration
        verified_cookie_name altcha_verified
        verified_cookie_ttl 3600           # 1 hour
        verified_cookie_secure true        # HTTPS only
        verified_cookie_http_only true     # No JS access
        verified_cookie_same_site Strict   # CSRF protection
    }

    # Rate limit contact form submissions
    @contact_submit path /contact/submit
    handle @contact_submit {
        import rate_limit_contact
        reverse_proxy http://127.0.0.1:8080
    }

    reverse_proxy http://127.0.0.1:8080
}

# =============================================================================
# EXAMPLE 3: Multi-Route Protection (Authentication + Registration)
# =============================================================================
auth.example.com {
    tls {
        dns cloudns {
            auth_id {$CLOUDNS_AUTH_ID}
            auth_password {$CLOUDNS_AUTH_PASSWORD}
        }
        propagation_delay 2m
        propagation_timeout -1
        resolvers 1.1.1.1 8.8.8.8
    }

    order altcha_verify before reverse_proxy

    # Challenge generation
    route /api/altcha/challenge {
        altcha_challenge {
            hmac_key {env.ALTCHA_HMAC_KEY}
            algorithm SHA-256
            max_number 1000000
            expires 5m
            rate_limit_requests 20
            rate_limit_window 1m
        }
    }

    # Challenge UI
    route /captcha* {
        rewrite * /index.html
        root * /var/www/altcha
        file_server
    }

    # Protect multiple authentication routes
    @auth_routes {
        path /login /register /reset-password /verify-email
        method POST
    }

    altcha_verify @auth_routes {
        hmac_key {env.ALTCHA_HMAC_KEY}
        session_backend redis://localhost:6379/1   # Use DB 1 for auth
        session_ttl 5m
        challenge_redirect /captcha
        preserve_post_data true
        verified_cookie_ttl 7200    # 2 hours for auth routes
    }

    # Strict rate limiting on login attempts
    @login path /login
    handle @login {
        import rate_limit_admin_login
        reverse_proxy http://127.0.0.1:8080
    }

    reverse_proxy http://127.0.0.1:8080
}

# =============================================================================
# EXAMPLE 4: API Protection with File Backend
# =============================================================================
api.example.com {
    tls {
        dns cloudns {
            auth_id {$CLOUDNS_AUTH_ID}
            auth_password {$CLOUDNS_AUTH_PASSWORD}
        }
        propagation_delay 2m
        propagation_timeout -1
        resolvers 1.1.1.1 8.8.8.8
    }

    order altcha_verify before reverse_proxy

    # Challenge endpoint
    route /api/altcha/challenge {
        altcha_challenge {
            hmac_key {env.ALTCHA_HMAC_KEY}
            algorithm SHA-384          # Stronger algorithm
            max_number 1000000
            expires 3m                 # Shorter for API
        }
    }

    # Challenge UI
    route /captcha* {
        rewrite * /index.html
        root * /var/www/altcha
        file_server
    }

    # Protect public API endpoints (no authentication)
    @public_api {
        path /api/public/*
        method POST PUT DELETE
    }

    altcha_verify @public_api {
        hmac_key {env.ALTCHA_HMAC_KEY}
        session_backend file:///var/lib/caddy/altcha  # File-based persistence
        session_ttl 5m
        challenge_redirect /captcha
        preserve_post_data true
    }

    # Authenticated API endpoints skip ALTCHA
    @auth_api {
        path /api/v1/*
        header Authorization *
    }

    handle @auth_api {
        reverse_proxy http://127.0.0.1:3000
    }

    # GET requests don't need ALTCHA
    @get_requests method GET
    handle @get_requests {
        reverse_proxy http://127.0.0.1:3000
    }

    # Default: require ALTCHA or return 403
    respond "API requires authentication or ALTCHA verification" 403
}

# =============================================================================
# EXAMPLE 5: E-commerce with Separate Checkout Protection
# =============================================================================
shop.example.com {
    tls {
        dns cloudns {
            auth_id {$CLOUDNS_AUTH_ID}
            auth_password {$CLOUDNS_AUTH_PASSWORD}
        }
        propagation_delay 2m
        propagation_timeout -1
        resolvers 1.1.1.1 8.8.8.8
    }

    order altcha_verify before reverse_proxy
    import security_headers

    # Challenge with strict rate limiting
    route /api/altcha/challenge {
        altcha_challenge {
            hmac_key {env.ALTCHA_HMAC_KEY}
            algorithm SHA-256
            max_number 1000000
            expires 5m
            rate_limit_requests 15
            rate_limit_window 1m
        }
    }

    # Challenge UI
    route /captcha* {
        rewrite * /index.html
        root * /var/www/altcha
        file_server
    }

    # Strict protection on checkout/payment
    @checkout {
        path /checkout /payment /order/submit
        method POST
    }

    altcha_verify @checkout {
        hmac_key {env.ALTCHA_HMAC_KEY}
        session_backend redis://localhost:6379/2
        session_ttl 10m              # Longer for checkout process
        challenge_redirect /captcha
        preserve_post_data true
        verified_cookie_ttl 1800     # 30 minutes
    }

    # Lenient protection on cart/wishlist operations
    @cart {
        path /cart/* /wishlist/*
        method POST PUT DELETE
    }

    altcha_verify @cart {
        hmac_key {env.ALTCHA_HMAC_KEY}
        session_backend redis://localhost:6379/2
        session_ttl 5m
        challenge_redirect /captcha
        preserve_post_data false     # Not critical for cart ops
        verified_cookie_ttl 3600
    }

    # Rate limit checkout operations
    @checkout_rate path /checkout /payment
    handle @checkout_rate {
        import rate_limit_checkout
        reverse_proxy http://127.0.0.1:8080
    }

    # Browse products freely
    reverse_proxy http://127.0.0.1:8080
}

# =============================================================================
# EXAMPLE 6: Using Snippets (Simplified Configuration)
# =============================================================================
simple.example.com {
    import cloudns_dns
    order altcha_verify before reverse_proxy
    import security_headers

    # Use pre-configured challenge endpoint
    import altcha_challenge_basic

    # Use pre-configured challenge page
    import altcha_challenge_page

    # Protect forms with memory backend
    @forms {
        path /contact /subscribe /feedback
        method POST
    }

    altcha_verify @forms {
        hmac_key {env.ALTCHA_HMAC_KEY}
        session_backend memory://
        challenge_redirect /captcha
        preserve_post_data true
    }

    reverse_proxy http://127.0.0.1:8080
}

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
#
# 1. Generate HMAC key:
#    export ALTCHA_HMAC_KEY=$(openssl rand -base64 32)
#
# 2. Create challenge UI directory:
#    mkdir -p /var/www/altcha
#
# 3. Create /var/www/altcha/index.html with ALTCHA widget
#    See: https://github.com/stardothosting/caddy-altcha/blob/main/examples/www/index.html
#
# 4. For Redis backend, ensure Redis is running:
#    redis-cli ping
#
# 5. Test challenge endpoint:
#    curl https://your-domain.com/api/altcha/challenge
#
# 6. Expected JSON response:
#    {
#      "algorithm": "SHA-256",
#      "challenge": "hex-string",
#      "maxNumber": 100000,
#      "salt": "hex-string",
#      "signature": "hmac-signature"
#    }
#
# IMPORTANT NOTES:
# - The same HMAC key MUST be used in both altcha_challenge and altcha_verify
# - Use 'order altcha_verify before reverse_proxy' to ensure verification runs first
# - Session backend is required for preserve_post_data functionality
# - Memory backend is fine for development but use Redis for production
# - The verified cookie allows users to make multiple requests without re-verification
