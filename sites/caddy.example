# Copy this file to /sites/<name>.caddy and replace domains/upstream.
# This default file is recreated at container startup if missing.
# Keep all hosts in one site block so DNS-01 is used for all names
# and one certificate can include every hostname listed here.
www.example.com, example.com, privacy.example.com {
    tls {
        dns cloudns {
            auth_id {$CLOUDNS_AUTH_ID}
            auth_password {$CLOUDNS_AUTH_PASSWORD}
        }

        # Equivalent to --dnssleep 120 in acme.sh.
        propagation_delay 2m
        propagation_timeout -1
        resolvers 1.1.1.1 8.8.8.8
    }

    @apex host example.com
    redir @apex https://www.example.com{uri} permanent

    @privacy host privacy.example.com
    redir @privacy https://thirdparty.example.com/privacy{uri} permanent

    @app host www.example.com
    reverse_proxy @app http://127.0.0.1:8080
}
