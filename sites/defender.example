# Copy this file to /sites/<name>.caddy and customize for your needs.
# This example demonstrates Caddy-Defender integration using JasonLovesDoggo/caddy-defender plugin.
#
# Caddy-Defender blocks AI training bots and cloud scrapers that ignore robots.txt.
# It uses IP range lists to identify known AI bot networks (OpenAI, DeepSeek, AWS, etc.)
#
# Plugin: https://github.com/JasonLovesDoggo/caddy-defender
# Purpose: Protect your content from AI training scrapers
#
# IMPORTANT: This is NOT for general security. Use for blocking AI bots only.

# =============================================================================
# EXAMPLE 1: Block All AI Training Bots (Recommended)
# =============================================================================
blog.example.com {
    # DNS-01 challenge for automatic HTTPS
    tls {
        dns cloudns {
            auth_id {$CLOUDNS_AUTH_ID}
            auth_password {$CLOUDNS_AUTH_PASSWORD}
        }
        propagation_delay 2m
        propagation_timeout -1
        resolvers 1.1.1.1 8.8.8.8
    }

    import security_headers

    # Block OpenAI, DeepSeek, GitHub Copilot, and cloud providers
    defender block {
        ranges openai deepseek githubcopilot aws gcloud azurepubliccloud
        message "AI training bots are not permitted. Respect robots.txt."
    }

    # Your content
    root * /var/www/blog
    file_server
    php_fastcgi unix//run/php/php8.2-fpm.sock
}

# =============================================================================
# EXAMPLE 2: Return Garbage Data (Poison AI Training)
# =============================================================================
api.example.com {
    tls {
        dns cloudns {
            auth_id {$CLOUDNS_AUTH_ID}
            auth_password {$CLOUDNS_AUTH_PASSWORD}
        }
        propagation_delay 2m
        propagation_timeout -1
        resolvers 1.1.1.1 8.8.8.8
    }

    # Return random garbage to pollute AI training data
    defender garbage {
        ranges openai deepseek githubcopilot aws gcloud azurepubliccloud
    }

    # Real API endpoint
    reverse_proxy http://127.0.0.1:3000
}

# =============================================================================
# EXAMPLE 3: Redirect to Notice Page
# =============================================================================
docs.example.com {
    tls {
        dns cloudns {
            auth_id {$CLOUDNS_AUTH_ID}
            auth_password {$CLOUDNS_AUTH_PASSWORD}
        }
        propagation_delay 2m
        propagation_timeout -1
        resolvers 1.1.1.1 8.8.8.8
    }

    import security_headers

    # Redirect AI bots to a notice page explaining your policy
    defender redirect {
        ranges openai deepseek githubcopilot aws gcloud azurepubliccloud
        url https://docs.example.com/ai-bot-policy
    }

    # AI bot policy page (exempted)
    @policy path /ai-bot-policy
    handle @policy {
        respond <<HTML
<!DOCTYPE html>
<html>
<head>
    <title>AI Bot Policy</title>
</head>
<body>
    <h1>Automated Access Notice</h1>
    <p>This website does not permit automated scraping or AI training.</p>
    <p>Please respect our robots.txt file.</p>
    <p>For licensing inquiries, contact: legal@example.com</p>
</body>
</html>
HTML 200
    }

    # Documentation content
    root * /var/www/docs
    file_server
}

# =============================================================================
# EXAMPLE 4: Tarpit (Slow Response)
# =============================================================================
portfolio.example.com {
    tls {
        dns cloudns {
            auth_id {$CLOUDNS_AUTH_ID}
            auth_password {$CLOUDNS_AUTH_PASSWORD}
        }
        propagation_delay 2m
        propagation_timeout -1
        resolvers 1.1.1.1 8.8.8.8
    }

    # Slow down AI bots with delayed responses
    defender tarpit {
        ranges openai deepseek githubcopilot aws gcloud azurepubliccloud
    }

    # Your portfolio site
    root * /var/www/portfolio
    file_server
}

# =============================================================================
# EXAMPLE 5: Drop Connection (Silent Ignore)
# =============================================================================
creative.example.com {
    tls {
        dns cloudns {
            auth_id {$CLOUDNS_AUTH_ID}
            auth_password {$CLOUDNS_AUTH_PASSWORD}
        }
        propagation_delay 2m
        propagation_timeout -1
        resolvers 1.1.1.1 8.8.8.8
    }

    # Silently drop connections from AI bots (no response)
    defender drop {
        ranges openai deepseek githubcopilot aws gcloud azurepubliccloud
    }

    # Your creative content
    reverse_proxy http://127.0.0.1:8080
}

# =============================================================================
# EXAMPLE 6: Selective Protection (Different Actions per Bot)
# =============================================================================
shop.example.com {
    tls {
        dns cloudns {
            auth_id {$CLOUDNS_AUTH_ID}
            auth_password {$CLOUDNS_AUTH_PASSWORD}
        }
        propagation_delay 2m
        propagation_timeout -1
        resolvers 1.1.1.1 8.8.8.8
    }

    import security_headers

    # Block specific AI companies
    defender block {
        ranges openai deepseek
        message "OpenAI and DeepSeek bots are not permitted."
    }

    # Return garbage to GitHub Copilot
    defender garbage {
        ranges githubcopilot
    }

    # Tarpit cloud providers
    defender tarpit {
        ranges aws gcloud azurepubliccloud
    }

    # E-commerce application
    reverse_proxy http://127.0.0.1:8080
}

# =============================================================================
# EXAMPLE 7: Custom IP Ranges with Block
# =============================================================================
custom.example.com {
    tls {
        dns cloudns {
            auth_id {$CLOUDNS_AUTH_ID}
            auth_password {$CLOUDNS_AUTH_PASSWORD}
        }
        propagation_delay 2m
        propagation_timeout -1
        resolvers 1.1.1.1 8.8.8.8
    }

    # Block custom IP ranges alongside known AI bots
    defender block {
        ranges openai deepseek githubcopilot aws gcloud azurepubliccloud custom
        custom_ranges 192.0.2.0/24 203.0.113.0/24
        message "Automated access not permitted."
    }

    reverse_proxy http://127.0.0.1:8080
}

# =============================================================================
# EXAMPLE 8: Protect Specific Routes Only
# =============================================================================
mixed.example.com {
    tls {
        dns cloudns {
            auth_id {$CLOUDNS_AUTH_ID}
            auth_password {$CLOUDNS_AUTH_PASSWORD}
        }
        propagation_delay 2m
        propagation_timeout -1
        resolvers 1.1.1.1 8.8.8.8
    }

    import security_headers

    # Block AI bots on premium content routes only
    @premium {
        path /premium/* /members/*
    }

    handle @premium {
        defender block {
            ranges openai deepseek githubcopilot aws gcloud azurepubliccloud
            message "AI training bots not allowed on premium content."
        }
        reverse_proxy http://127.0.0.1:8080
    }

    # Allow public content to be indexed
    handle {
        reverse_proxy http://127.0.0.1:8080
    }
}

# =============================================================================
# EXAMPLE 9: Using Snippets (Simplified Configuration)
# =============================================================================
simple.example.com {
    import cloudns_dns
    import security_headers

    # Use pre-configured defender snippet
    import defender_block_ai

    # Your application
    reverse_proxy http://127.0.0.1:8080
}

# =============================================================================
# EXAMPLE 10: Combining with ALTCHA (Multi-Layer Protection)
# =============================================================================
secure.example.com {
    import cloudns_dns
    order altcha_verify before reverse_proxy
    import security_headers

    # Layer 1: Block AI training bots
    import defender_block_ai

    # Layer 2: ALTCHA challenge endpoint
    import altcha_challenge_basic

    # Layer 3: ALTCHA verification on forms
    @forms {
        path /contact /register /login
        method POST
    }

    altcha_verify @forms {
        hmac_key {env.ALTCHA_HMAC_KEY}
        session_backend redis://localhost:6379/0
        challenge_redirect /captcha
        preserve_post_data true
    }

    # Layer 4: Rate limiting
    @contact path /contact
    handle @contact {
        import rate_limit_contact
        reverse_proxy http://127.0.0.1:8080
    }

    reverse_proxy http://127.0.0.1:8080
}

# =============================================================================
# AVAILABLE IP RANGES
# =============================================================================
#
# Built-in ranges (updated regularly by plugin):
# - openai          OpenAI GPT crawlers
# - deepseek        DeepSeek AI training bots
# - githubcopilot   GitHub Copilot training sources
# - aws             Amazon Web Services IP ranges
# - gcloud          Google Cloud Platform IP ranges
# - azurepubliccloud  Microsoft Azure public cloud IP ranges
# - custom          Your own IP ranges (requires custom_ranges parameter)
#
# To see current IP ranges:
# https://github.com/JasonLovesDoggo/caddy-defender/tree/main/ranges

# =============================================================================
# AVAILABLE ACTIONS
# =============================================================================
#
# block      Return 403 Forbidden with optional message
# garbage    Return random garbage data (pollute training)
# redirect   HTTP 302 redirect to specified URL
# tarpit     Slow response (waste bot resources)
# drop       Silently drop connection (no response)

# =============================================================================
# USAGE NOTES
# =============================================================================
#
# 1. Purpose: This plugin blocks AI training bots that scrape content.
#    It is NOT for general security, malware, or DDoS protection.
#
# 2. robots.txt: Always have a robots.txt file that disallows AI bots.
#    Example:
#      User-agent: GPTBot
#      User-agent: ChatGPT-User
#      User-agent: Google-Extended
#      User-agent: CCBot
#      User-agent: anthropic-ai
#      User-agent: Claude-Web
#      Disallow: /
#
# 3. Legal: Blocking AI bots is currently legal in most jurisdictions.
#    The plugin helps enforce your robots.txt policy.
#
# 4. Performance: IP range checks are fast and have minimal overhead.
#    Use 'block' action for best performance.
#
# 5. Updates: The plugin automatically pulls updated IP ranges.
#    Keep your Caddy installation updated for latest ranges.
#
# 6. Testing: To test if blocking works, use a VPN or proxy from a cloud provider.
#    AWS/GCloud/Azure IPs will trigger the defender.
#
# 7. Whitelisting: If you need to allow specific IPs from blocked ranges,
#    use a @whitelist matcher before the defender directive:
#
#    @whitelist {
#        remote_ip 203.0.113.45
#    }
#    handle @whitelist {
#        reverse_proxy http://127.0.0.1:8080
#    }
#
#    defender block {
#        ranges openai deepseek githubcopilot aws gcloud azurepubliccloud
#    }

# =============================================================================
# RECOMMENDED CONFIGURATION
# =============================================================================
#
# For most sites, use this simple configuration:
#
# yoursite.com {
#     import cloudns_dns
#     import security_headers
#     import defender_block_ai
#
#     # Your site configuration
#     reverse_proxy http://127.0.0.1:8080
# }
#
# This blocks all major AI training bots with a 403 response.
