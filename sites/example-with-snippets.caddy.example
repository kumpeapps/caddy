# Example site configuration using snippets
# Copy this file to create your own site configuration
# Note: Snippets and matchers are automatically imported globally in Caddyfile

# =============================================================================
# EXAMPLE 1: Basic Website with Security
# =============================================================================
www.example.com, example.com {
    # CloudNS DNS-01 challenge
    import cloudns_dns
    
    # Redirect apex to www
    @apex host example.com
    redir @apex https://www.example.com{uri} permanent
    
    # Security headers
    import security_headers
    
    # Basic bot protection
    import bot_protection
    
    # Exploit protection
    import exploit_protection
    
    # General rate limiting
    import rate_limit_general
    
    # Compression
    import compression
    
    # Static asset caching
    import static_cache
    
    # Logging
    import log_common
    
    # Reverse proxy to application
    reverse_proxy http://127.0.0.1:8080 {
        import reverse_proxy_defaults
    }
}

# =============================================================================
# EXAMPLE 2: API Server with CORS
# =============================================================================
api.example.com {
    import cloudns_dns
    import security_headers
    import bot_protection_strict
    import compression
    
    # API rate limiting
    @api path /api/*
    handle @api {
        import cors_permissive
        import rate_limit_api
        reverse_proxy http://127.0.0.1:3000 {
            import reverse_proxy_defaults
        }
    }
    
    # Login endpoint with strict rate limiting
    @login path /login /auth/*
    handle @login {
        import rate_limit_login
        reverse_proxy http://127.0.0.1:3000 {
            import reverse_proxy_defaults
        }
    }
    
    # Health check (no rate limit)
    @health path /health /healthz
    handle @health {
        reverse_proxy http://127.0.0.1:3000
    }
    
    # Default
    reverse_proxy http://127.0.0.1:3000 {
        import reverse_proxy_defaults
    }
}

# =============================================================================
# EXAMPLE 3: Static File Server
# =============================================================================
static.example.com {
    import cloudns_dns
    import security_headers
    import compression
    import static_cache
    
    # Lenient rate limiting for static content
    import rate_limit_lenient
    
    root * /var/www/html
    import file_server_defaults
}

# =============================================================================
# EXAMPLE 4: Admin Panel (Protected)
# =============================================================================
admin.example.com {
    import cloudns_dns
    import security_headers_strict
    import exploit_protection
    
    # Very strict rate limiting
    import rate_limit_strict
    
    # Uncomment and configure basic auth
    # basicauth {
    #     admin $2a$14$Zkx19XLiW6VYouLHR5NmfOFU0z2GTNmpkT/5qqR7hx4IjWJPDhjvG
    # }
    
    reverse_proxy http://127.0.0.1:9000 {
        import reverse_proxy_defaults
    }
}

# =============================================================================
# EXAMPLE 5: Multiple Features Combined
# =============================================================================
shop.example.com {
    import cloudns_dns
    import security_headers
    import bot_protection
    import exploit_protection
    import compression
    import log_detailed
    
    # Admin section - protected
    @admin path /admin/*
    handle @admin {
        import rate_limit_login
        # Add basic auth here if needed
        reverse_proxy http://127.0.0.1:8080 {
            import reverse_proxy_defaults
        }
    }
    
    # Checkout - strict rate limiting
    @checkout path /checkout /payment /order
    handle @checkout {
        import rate_limit_strict
        reverse_proxy http://127.0.0.1:8080 {
            import reverse_proxy_defaults
        }
    }
    
    # API endpoints
    @api path /api/*
    handle @api {
        import cors_restricted
        import rate_limit_api
        reverse_proxy http://127.0.0.1:8080 {
            import reverse_proxy_defaults
        }
    }
    
    # Static assets - aggressive caching
    handle @static_assets {
        import static_cache
        reverse_proxy http://127.0.0.1:8080 {
            import reverse_proxy_defaults
        }
    }
    
    # Default handler
    import rate_limit_general
    reverse_proxy http://127.0.0.1:8080 {
        import reverse_proxy_defaults
    }
}

